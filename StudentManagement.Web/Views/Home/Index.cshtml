@using System.Security.Claims
@{
    ViewData["Title"] = "Dashboard";
    var email = User.Identity?.Name ?? "User";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "Guest";
    
    // Formatting email as display name (e.g. admin@school.com -> Admin)
    var displayName = email.Contains("@") ? email.Split('@')[0] : email;
    if (!string.IsNullOrEmpty(displayName))
    {
        displayName = char.ToUpper(displayName[0]) + displayName.Substring(1);
    }
}

<!-- HERO BANNER -->
<div class="hero-wrap">
    <div class="hero-banner">
        <div class="greeting">
            Good Morning, <span class="user-name">@displayName <small style="font-size: 14px; opacity: 0.8; font-weight: normal;">(@role)</small></span>
            <span class="wave">👋</span>
        </div>

        <div class="hero-right">
            <span class="tagline">Consistency beats intensity.</span>
            <div class="date-pill"><i class="bi bi-calendar-event"></i> Monday, July 13, 2026</div>
            <div class="team-icon"><i class="bi bi-people-fill"></i></div>
        </div>
    </div>
</div>