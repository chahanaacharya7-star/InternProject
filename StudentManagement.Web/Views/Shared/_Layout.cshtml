<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudentManagement</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @* <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /> *@
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/StudentManagement.Web.styles.css" asp-append-version="true" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body>
    
    <div class="topbar-strip"></div>

    <!-- HEADER -->
    <header class="top-header">
        <div class="logo-section">
            <img src="~/images/logo.png" class="logo" />
            <div class="logo-text">
                <h3>MIS</h3>
                <button class="theme-toggle" id="themeToggle" title="Toggle dark / light mode">
                    <i class="bi bi-moon-fill"></i>
                </button>
                <span>P1Soft</span>
            </div>
        </div>

        <!--Search Box-->
        <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search here (Ctrl + /) · Ctrl + S for advanced search" />
        </div>

        <!--Header icons-->
        <div class="header-icons">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span class="user-role-badge">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
            }
            <i class="bi bi-person"></i>
            <i class="bi bi-person-plus"></i>
            <i class="bi bi-headset accent"></i>
            <i class="bi bi-chat-square"></i>
            <i class="bi bi-bell"></i>
            <div class="avatar" title="Signed in as: @User.Identity?.Name">
                <img src="~/images/user.png" class="profile" />
                <span class="status-dot"></span>
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Account" asp-action="Logout" class="logout-btn" title="Sign Out">
                    <i class="bi bi-box-arrow-right" style="color: #ef4444;"></i>
                </a>
            }
        </div>
    </header>

    <!-- NAVBAR -->
    <nav class="main-navbar">
        <button class="nav-arrow">‹</button>
        <ul>
            <li><a asp-controller="Home" asp-action="Index"><i class="bi bi-house-door"></i></a></li>
            <li class="has-dropdown">
                <a href="#" class="dropdown-trigger" data-dropdown="pis-dropdown">
                    <i class="bi bi-person-badge"></i> PIS <i class="bi bi-caret-down-fill caret"></i>
                </a>
                <!--DropDown-->
                <!--PIS-->
                <div class="mega-dropdown" id="pis-dropdown">
                    <div class="mega-column">
                        <div class="mega-col-header">
                            <i class="bi bi-people-fill"></i>
                            <span>PIS</span>
                        </div>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Employee List</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Employee Login</a>
                    </div>

                    <div class="mega-column">
                        <div class="mega-col-header">
                            <i class="bi bi-calendar-check"></i>
                            <span>Attendance</span>
                        </div>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Attendance</a>
                    </div>
                </div>
            </li>

            <!--Setup-->
            <li class="has-dropdown">
                <a href="#" class="dropdown-trigger" data-dropdown="setup-dropdown">
                    <i class="bi bi-tools"></i> Setup <i class="bi bi-caret-down-fill caret"></i>
                </a>

                <div class="mega-dropdown" id="setup-dropdown">
                    <div class="mega-column">
                        <div class="mega-col-header">
                            <i class="bi bi-person"></i>
                            <span>User &amp; Permission</span>
                        </div>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> User List</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Roles &amp; Permission</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Mobile Permission</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Roles</a>
                    </div>

                    <div class="mega-column">
                        <div class="mega-col-header">
                            <i class="bi bi-person"></i>
                            <span>Organization Setup</span>
                        </div>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Company Setup</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Organization Setup</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Attendance General Settings</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Legal Entity</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Data Access Group</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Eligibility Profile Setup (PIS)</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Security Profile</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Derived Factor</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Employee Group</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Employee Group Dimension</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Municipality Setup</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Attendance Device Setup</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Other Setup</a>
                    </div>
                </div>
            </li>

            <!--School Admin-->
            <li class="has-dropdown">
                <a href="#" class="dropdown-trigger" data-dropdown="schooladmin-dropdown">
                    <i class="bi bi-building"></i> School Admin <i class="bi bi-caret-down-fill caret"></i>
                </a>

                <div class="mega-dropdown" id="schooladmin-dropdown">
                    <div class="mega-column">
                        <div class="mega-col-header">
                            <i class="bi bi-book"></i>
                            <span>Academic Setup</span>
                        </div>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Academic Setup</a>
                    </div>

                    <div class="mega-column">
                        <div class="mega-col-header">
                            <i class="bi bi-calendar3"></i>
                            <span>Calendar</span>
                        </div>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> AD Calendar</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> BS Calendar</a>
                    </div>

                    <div class="mega-column">
                        <div class="mega-col-header">
                            <i class="bi bi-book"></i>
                            <span>Teacher Allocation</span>
                        </div>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Assign Class Teacher</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Teacher Subject Allocation</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Batch Subject Allocation</a>
                    </div>

                    <div class="mega-column">
                        <div class="mega-col-header">
                            <i class="bi bi-bus-front"></i>
                            <span>Transportation</span>
                        </div>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Drivers Info</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Bus Stop</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Transport Route</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Vehicle Info</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Student Transport Mapping</a>
                        <a href="#"><i class="bi bi-chevron-double-right"></i> Student Transport Import</a>
                    </div>
                </div>
            </li>
            <li><a href="#"><i class="bi bi-journal-bookmark"></i> Academics <i class="bi bi-caret-down-fill caret"></i></a></li>
            <li><a href="#"><i class="bi bi-wallet2"></i> Fees/Billing <i class="bi bi-caret-down-fill caret"></i></a></li>
            <li><a href="#"><i class="bi bi-person-lines-fill"></i> Student Info <i class="bi bi-caret-down-fill caret"></i></a></li>
        </ul>
        <button class="nav-arrow">›</button>
    </nav>

    <!--Container-->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!--Footer-->
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - StudentManagement.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <!-- Script -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>

    <!-- Internal JS -->
    <script>
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = themeToggle.querySelector('i');

        function applyTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        themeIcon.className = theme === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
        localStorage.setItem('theme', theme);
        }

        const savedTheme = localStorage.getItem('theme') || 'light';
        applyTheme(savedTheme);

        themeToggle.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        applyTheme(current === 'dark' ? 'light' : 'dark');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>