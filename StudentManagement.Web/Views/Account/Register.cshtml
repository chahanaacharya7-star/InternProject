@model StudentManagement.Web.Models.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - School Management System</title>
    
    <!-- Google Fonts: Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    
    <!-- Custom CSS (Reusing the premium login styling) -->
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body class="login-body">

    <!-- Theme Toggle -->
    <div class="theme-toggle-container">
        <button class="login-theme-btn" id="themeToggleBtn" type="button" title="Toggle dark/light mode">
            <i class="bi bi-moon-fill" id="themeIcon"></i>
        </button>
    </div>

    <!-- Register Container -->
    <div class="login-container">
        <div class="login-card">
            
            <!-- Brand / Header -->
            <div class="brand-header">
                <div class="brand-logo-container">
                    <img src="~/images/logo.png" alt="School Logo" class="brand-logo" onerror="this.src='https://images.unsplash.com/photo-1546410531-bb4caa6b424d?auto=format&fit=crop&q=80&w=100'" />
                    <span class="brand-title">MIS Portal</span>
                </div>
                <p class="brand-subtitle">Create a new account to get started.</p>
            </div>

            <!-- Validation Summary -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
            }

            <!-- Form -->
            <form asp-action="Register" asp-controller="Account" method="post">

                <!-- Role Selection -->
                <div class="form-group">
                    <label class="form-label">Register as</label>
                    <div class="role-cards-container">
                        
                        <label class="role-card-label" for="role-student">
                            <input type="radio" asp-for="Role" value="Student" class="role-card-input" id="role-student" />
                            <div class="role-card">
                                <i class="bi bi-mortarboard-fill"></i>
                                <span>Student</span>
                            </div>
                        </label>

                        <label class="role-card-label" for="role-teacher">
                            <input type="radio" asp-for="Role" value="Teacher" class="role-card-input" id="role-teacher" />
                            <div class="role-card">
                                <i class="bi bi-person-workspace"></i>
                                <span>Teacher</span>
                            </div>
                        </label>

                        <label class="role-card-label" for="role-admin">
                            <input type="radio" asp-for="Role" value="Admin" class="role-card-input" id="role-admin" />
                            <div class="role-card">
                                <i class="bi bi-shield-lock-fill"></i>
                                <span>Admin</span>
                            </div>
                        </label>
                        
                    </div>
                    <span asp-validation-for="Role" class="text-danger-custom"></span>
                </div>

                <!-- Email / Username -->
                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email or Username</label>
                    <div class="input-wrapper">
                        <input asp-for="Email" class="form-control-custom" placeholder="e.g. yourname@school.com" autocomplete="username" required />
                        <i class="bi bi-envelope-fill input-icon"></i>
                    </div>
                    <span asp-validation-for="Email" class="text-danger-custom"></span>
                </div>

                <!-- Password -->
                <div class="form-group">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="input-wrapper">
                        <input asp-for="Password" type="password" class="form-control-custom" placeholder="••••••••" autocomplete="new-password" required />
                        <i class="bi bi-lock-fill input-icon"></i>
                    </div>
                    <span asp-validation-for="Password" class="text-danger-custom"></span>
                </div>

                <!-- Confirm Password -->
                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                    <div class="input-wrapper">
                        <input asp-for="ConfirmPassword" type="password" class="form-control-custom" placeholder="••••••••" autocomplete="new-password" required />
                        <i class="bi bi-lock-fill input-icon"></i>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger-custom"></span>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn-login" style="margin-top: 10px;">
                    <span>Sign Up</span>
                    <i class="bi bi-person-plus-fill" style="font-size: 18px;"></i>
                </button>

                <!-- Navigation link -->
                <div style="text-align: center; margin-top: 20px; font-size: 13.5px; color: var(--text-secondary);">
                    Already have an account? <a href="/Account/Login" class="forgot-link">Sign In</a>
                </div>
            </form>

        </div>
    </div>

    <!-- Core Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Theme Logic -->
    <script>
        const themeBtn = document.getElementById('themeToggleBtn');
        const themeIcon = document.getElementById('themeIcon');
        const htmlElem = document.documentElement;

        function applyTheme(theme) {
            htmlElem.setAttribute('data-theme', theme);
            if (theme === 'dark') {
                themeIcon.className = 'bi bi-sun-fill';
            } else {
                themeIcon.className = 'bi bi-moon-fill';
            }
            localStorage.setItem('theme', theme);
        }

        const savedTheme = localStorage.getItem('theme') || 'light';
        applyTheme(savedTheme);

        themeBtn.addEventListener('click', () => {
            const currentTheme = htmlElem.getAttribute('data-theme');
            applyTheme(currentTheme === 'dark' ? 'light' : 'dark');
        });
    </script>
</body>
</html>
