@model StudentManagement.Web.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - School Management System</title>
    
    <!-- Google Fonts: Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    
    <!-- Custom Login CSS -->
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <style>
        .success-alert-custom {
            background: rgba(16, 185, 129, 0.12);
            border: 1px solid rgba(16, 185, 129, 0.25);
            border-radius: 12px;
            padding: 12px 16px;
            margin-bottom: 24px;
            color: #a7f3d0;
            font-size: 13.5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .success-alert-custom i {
            color: #10b981;
            font-size: 16px;
        }
        [data-theme="light"] .success-alert-custom {
            background: rgba(16, 185, 129, 0.08);
            border-color: rgba(16, 185, 129, 0.2);
            color: #065f46;
        }
    </style>
</head>
<body class="login-body">

    <!-- Theme Toggle -->
    <div class="theme-toggle-container">
        <button class="login-theme-btn" id="themeToggleBtn" type="button" title="Toggle dark/light mode">
            <i class="bi bi-moon-fill" id="themeIcon"></i>
        </button>
    </div>

    <!-- Login Container -->
    <div class="login-container">
        <div class="login-card">
            
            <!-- Brand / Header -->
            <div class="brand-header">
                <div class="brand-logo-container">
                    <img src="~/images/logo.png" alt="School Logo" class="brand-logo" onerror="this.src='https://images.unsplash.com/photo-1546410531-bb4caa6b424d?auto=format&fit=crop&q=80&w=100'" />
                    <span class="brand-title">MIS Portal</span>
                </div>
                <p class="brand-subtitle">Welcome back! Please enter your details to sign in.</p>
            </div>

            <!-- Validation Summary -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
            }

            <!-- Success Message -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="success-alert-custom">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@TempData["SuccessMessage"]</span>
                </div>
            }

            <!-- Form -->
            <form asp-action="Login" asp-controller="Account" method="post">

                <!-- Role Selection -->
                <div class="form-group">
                    <label class="form-label">Sign in as</label>
                    <div class="role-cards-container">
                        
                        <label class="role-card-label" for="role-student">
                            <input type="radio" asp-for="Role" value="Student" class="role-card-input" id="role-student" />
                            <div class="role-card">
                                <i class="bi bi-mortarboard-fill"></i>
                                <span>Student</span>
                            </div>
                        </label>

                        <label class="role-card-label" for="role-teacher">
                            <input type="radio" asp-for="Role" value="Teacher" class="role-card-input" id="role-teacher" />
                            <div class="role-card">
                                <i class="bi bi-person-workspace"></i>
                                <span>Teacher</span>
                            </div>
                        </label>

                        <label class="role-card-label" for="role-admin">
                            <input type="radio" asp-for="Role" value="Admin" class="role-card-input" id="role-admin" />
                            <div class="role-card">
                                <i class="bi bi-shield-lock-fill"></i>
                                <span>Admin</span>
                            </div>
                        </label>
                        
                    </div>
                    <span asp-validation-for="Role" class="text-danger-custom"></span>
                </div>

                <!-- Email / Username -->
                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email or Username</label>
                    <div class="input-wrapper">
                        <input asp-for="Email" class="form-control-custom" placeholder="e.g. admin@school.com" autocomplete="username" required />
                        <i class="bi bi-envelope-fill input-icon"></i>
                    </div>
                    <span asp-validation-for="Email" class="text-danger-custom"></span>
                </div>

                <!-- Password -->
                <div class="form-group">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="input-wrapper">
                        <input asp-for="Password" type="password" class="form-control-custom" placeholder="••••••••" autocomplete="current-password" required />
                        <i class="bi bi-lock-fill input-icon"></i>
                    </div>
                    <span asp-validation-for="Password" class="text-danger-custom"></span>
                </div>

                <!-- Helpers (Remember Me & Forgot Password) -->
                <div class="form-helpers">
                    <label class="remember-me-container" for="RememberMe">
                        <input asp-for="RememberMe" type="checkbox" />
                        <span>Remember me</span>
                    </label>
                    <a href="#" class="forgot-link" onclick="alert('Please contact the administration office to reset your password.')">Forgot Password?</a>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn-login">
                    <span>Sign In</span>
                    <i class="bi bi-arrow-right-short" style="font-size: 20px;"></i>
                </button>

                <!-- Navigation link -->
                <div style="text-align: center; margin-top: 20px; font-size: 13.5px; color: var(--text-secondary);">
                    Don't have an account? <a href="/Account/Register" class="forgot-link">Sign Up</a>
                </div>
            </form>

            <!-- Demo Credentials Widget -->
            <div class="demo-panel">
                <div class="demo-title">Quick Demo Sign-In</div>
                <div class="demo-pills">
                    <button type="button" class="demo-pill-btn" onclick="autofillDemo('admin@school.com', 'Admin@123', 'Admin')">
                        <i class="bi bi-shield-lock"></i>
                        <span>Admin</span>
                    </button>
                    <button type="button" class="demo-pill-btn" onclick="autofillDemo('teacher@school.com', 'Teacher@123', 'Teacher')">
                        <i class="bi bi-person-workspace"></i>
                        <span>Teacher</span>
                    </button>
                    <button type="button" class="demo-pill-btn" onclick="autofillDemo('student@school.com', 'Student@123', 'Student')">
                        <i class="bi bi-mortarboard"></i>
                        <span>Student</span>
                    </button>
                </div>
            </div>

        </div>
    </div>

    <!-- Quick Success Toast for Autofill -->
    <div class="autofill-notification" id="toastNotification">
        <i class="bi bi-check-circle-fill"></i>
        <span id="toastMsg">Autofilled successfully!</span>
    </div>

    <!-- Core Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Theme Logic & Dynamic Interactions -->
    <script>
        // Theme Toggle script
        const themeBtn = document.getElementById('themeToggleBtn');
        const themeIcon = document.getElementById('themeIcon');
        const htmlElem = document.documentElement;

        function applyTheme(theme) {
            htmlElem.setAttribute('data-theme', theme);
            if (theme === 'dark') {
                themeIcon.className = 'bi bi-sun-fill';
            } else {
                themeIcon.className = 'bi bi-moon-fill';
            }
            localStorage.setItem('theme', theme);
        }

        const savedTheme = localStorage.getItem('theme') || 'light';
        applyTheme(savedTheme);

        themeBtn.addEventListener('click', () => {
            const currentTheme = htmlElem.getAttribute('data-theme');
            applyTheme(currentTheme === 'dark' ? 'light' : 'dark');
        });

        // Interactive Autofill script
        function autofillDemo(email, password, role) {
            const emailInput = document.getElementById('Email');
            const passInput = document.getElementById('Password');
            
            // Set values
            emailInput.value = email;
            passInput.value = password;

            // Trigger radio button checks
            const radioId = 'role-' + role.toLowerCase();
            const radioElem = document.getElementById(radioId);
            if (radioElem) {
                radioElem.checked = true;
            }

            // Flash effect for feedback
            emailInput.style.transition = 'none';
            passInput.style.transition = 'none';
            emailInput.style.boxShadow = '0 0 0 4px rgba(16, 185, 129, 0.4)';
            passInput.style.boxShadow = '0 0 0 4px rgba(16, 185, 129, 0.4)';
            
            setTimeout(() => {
                emailInput.style.transition = 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
                passInput.style.transition = 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
                emailInput.style.boxShadow = 'none';
                passInput.style.boxShadow = 'none';
            }, 300);

            // Toast feedback
            showToast(`Autofilled for ${role}! Click Sign In.`);
        }

        function showToast(message) {
            const toast = document.getElementById('toastNotification');
            const toastMsg = document.getElementById('toastMsg');
            toastMsg.textContent = message;
            toast.classList.add('show');
            
            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }
    </script>
</body>
</html>
